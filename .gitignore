# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files — ALL .env variants, never commit any of these.
# .env*.local was the original line, but plain .env was leaking through.
.env
.env.*

# manual file backups (we have git, don't need these tracked)
*.bak

# personal workflow / scratch helpers — Andy's local scripts that aren't
# part of the project's canonical npm scripts. Keep local, don't ship.
do-*.ps1
push-*.ps1
eas-push*.bat
eas-check*.bat

# scratch debug output captured to file during OTA + build investigations
eas-out.txt*
eas-check*.log
eas-list*.log
eas-push*.log
scripts/competitor-research/eas-build*.log
scripts/competitor-research/eas-submit*.log
scripts/competitor-research/eas-update*.log

# pnpm files — project uses npm; pnpm-lock + workspace are dead artifacts
# from a brief experiment, would only confuse future contributors.
pnpm-lock.yaml
pnpm-workspace.yaml

# coord-validation output (large logs, contains place_ids — keep local)
coord_corrections.jsonl

# OSM Overpass cache for the building fetcher — 27MB raw OSM dump,
# regeneratable via `npm run fetch-osm-buildings`. Per-terrace
# pre-computed result lives in src/data/buildings.json (committed).
scripts/competitor-research/osm-buildings-with-heights.json
scripts/competitor-research/fetch-buildings.log
scripts/competitor-research/fetch-3dbag.log
scripts/__pycache__/

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
